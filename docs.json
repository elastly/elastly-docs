{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Elastly",
  "description": "Per-line, explainable prices that learn from your real sales outcomes. Connect your ERP or storefront, set your guardrails, and review every recommendation before it ships.",
  "colors": {
    "primary": "#0e8c6b",
    "light": "#38a584",
    "dark": "#0a6b52"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://elastly.io"
  },
  "fonts": {
    "heading": {
      "family": "Bricolage Grotesque",
      "weight": 700
    },
    "body": {
      "family": "Geist"
    }
  },
  "styling": {
    "eyebrows": "section"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["bash", "typescript", "python", "php", "java", "go"]
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "pages": ["index", "quickstart", "connectors"]
      },
      {
        "group": "API reference",
        "icon": "terminal",
        "pages": [
          {
            "group": "Prices",
            "icon": "tag",
            "pages": ["api/endpoints/get-prices"]
          },
          {
            "group": "Ingest",
            "icon": "arrow-down-to-line",
            "pages": [
              "api/endpoints/create-ingest-batch",
              "api/endpoints/stage-ingest-records",
              "api/endpoints/commit-ingest-batch",
              "api/endpoints/get-ingest-batch-status"
            ]
          },
          {
            "group": "Write-backs",
            "icon": "arrow-up-from-line",
            "pages": ["api/endpoints/claim-writebacks", "api/endpoints/ack-writebacks"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://elastly.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://app.elastly.io"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/elastlyio",
      "github": "https://github.com/elastly",
      "linkedin": "https://www.linkedin.com/company/elastly"
    }
  }
}
