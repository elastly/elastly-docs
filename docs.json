{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Elastly",
  "description": "Per-line, explainable prices that learn from your real sales outcomes. Connect your ERP or storefront, set your guardrails, and review every recommendation before it ships.",
  "colors": {
    "primary": "#0e8c6b",
    "light": "#38a584",
    "dark": "#0a6b52"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://elastly.io"
  },
  "fonts": {
    "heading": {
      "family": "Bricolage Grotesque",
      "weight": 700
    },
    "body": {
      "family": "Geist"
    }
  },
  "styling": {
    "eyebrows": "section"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": [
        "bash",
        "typescript",
        "python",
        "php",
        "java",
        "go"
      ]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "connectors",
              "field-mapping"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "strategies",
              "guardrails",
              "explainability"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "connect-netsuite",
              "connect-shopify",
              "connect-bigcommerce",
              "connect-woocommerce",
              "connect-salla"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "icon": "code",
        "groups": [
          {
            "group": "SDKs",
            "pages": [
              "sdks",
              "sdks/typescript",
              "sdks/python",
              "sdks/php",
              "sdks/java",
              "sdks/go",
              {
                "group": "Build a connector",
                "pages": [
                  "sdks/build-a-connector",
                  "sdks/build-a-connector/connector-framework",
                  "sdks/build-a-connector/feeding-data",
                  "sdks/build-a-connector/applying-prices"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/overview"
            ]
          },
          {
            "group": "Prices",
            "icon": "tag",
            "pages": [
              "api/endpoints/get-prices"
            ]
          },
          {
            "group": "Ingest",
            "icon": "arrow-down-to-line",
            "pages": [
              "api/ingest",
              "api/endpoints/create-ingest-batch",
              "api/endpoints/stage-ingest-records",
              "api/endpoints/commit-ingest-batch",
              "api/endpoints/get-ingest-batch-status"
            ]
          },
          {
            "group": "Write-backs",
            "icon": "arrow-up-from-line",
            "pages": [
              "api/writebacks",
              "api/endpoints/claim-writebacks",
              "api/endpoints/ack-writebacks"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://elastly.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://app.elastly.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/elastlyio",
      "github": "https://github.com/elastly",
      "linkedin": "https://www.linkedin.com/company/elastly"
    }
  },
  "redirects": [
    {
      "source": "/sdk-python",
      "destination": "/sdks/python"
    },
    {
      "source": "/sdk-php",
      "destination": "/sdks/php"
    },
    {
      "source": "/sdk-java",
      "destination": "/sdks/java"
    },
    {
      "source": "/sdk-go",
      "destination": "/sdks/go"
    },
    {
      "source": "/sdk",
      "destination": "/sdks/typescript"
    },
    {
      "source": "/build-a-connector",
      "destination": "/sdks/build-a-connector"
    },
    {
      "source": "/sdks/build-a-connector/typescript-framework",
      "destination": "/sdks/build-a-connector/connector-framework"
    }
  ]
}
